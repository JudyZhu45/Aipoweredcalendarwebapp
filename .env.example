# Copy this file to .env.local and fill in your values

# Lambda streaming endpoint (AI agent)
VITE_AGENT_API_URL=https://your-api-gateway-url/chat
VITE_AGENT_STREAM_URL=https://your-lambda-function-url.on.aws/

# AWS / Amplify (find these in your AWS Amplify or Cognito console)
VITE_AWS_REGION=us-east-1
VITE_APPSYNC_ENDPOINT=https://xxxxxxxxxx.appsync-api.us-east-1.amazonaws.com/graphql
VITE_APPSYNC_API_KEY=da2-xxxxxxxxxx
VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
